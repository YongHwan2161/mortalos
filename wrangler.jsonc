{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mortalos-lab-yonghwan2161",
  "pages_build_output_dir": "./dist/lab",
  "compatibility_date": "2026-07-17",
  "vars": {
    "ENVIRONMENT": "production"
  },
  "ratelimits": [
    {
      "name": "SCENARIO_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 10,
        "period": 60
      }
    }
  ]
}

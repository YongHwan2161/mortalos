{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mortalos.dev/schemas/v0/pulse.schema.json",
  "title": "MortalOS v0 Pulse Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "body", "approvals", "acceptances"],
  "properties": {
    "kind": {
      "const": "mortalos.pulse"
    },
    "body": {
      "$ref": "#/$defs/pulseBody"
    },
    "approvals": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "acceptances": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string"
    },
    "organismId": {
      "type": "string"
    },
    "peerId": {
      "type": "string"
    },
    "publicKey": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "sequence": {
      "type": "string"
    },
    "custodian": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "public_key"],
      "properties": {
        "key_id": {
          "$ref": "#/$defs/peerId"
        },
        "public_key": {
          "$ref": "#/$defs/publicKey"
        }
      }
    },
    "quorum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "threshold"],
      "properties": {
        "type": {
          "type": "string"
        },
        "threshold": {
          "type": "integer"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "signature"],
      "properties": {
        "key_id": {
          "$ref": "#/$defs/peerId"
        },
        "signature": {
          "$ref": "#/$defs/signature"
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "payload_hash"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "payload_hash": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "pulseBody": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "organism_id",
        "sequence",
        "parent_hash",
        "genome_hash",
        "current_custody_hash",
        "state_root",
        "event",
        "next_custodians",
        "next_quorum"
      ],
      "properties": {
        "protocol_version": {
          "const": "mortalos/0"
        },
        "organism_id": {
          "$ref": "#/$defs/organismId"
        },
        "sequence": {
          "$ref": "#/$defs/sequence"
        },
        "parent_hash": {
          "$ref": "#/$defs/digest"
        },
        "genome_hash": {
          "$ref": "#/$defs/digest"
        },
        "current_custody_hash": {
          "$ref": "#/$defs/digest"
        },
        "state_root": {
          "$ref": "#/$defs/digest"
        },
        "event": {
          "$ref": "#/$defs/event"
        },
        "next_custodians": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/custodian"
          }
        },
        "next_quorum": {
          "$ref": "#/$defs/quorum"
        }
      }
    }
  }
}

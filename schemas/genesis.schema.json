{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mortalos.dev/schemas/v0/genesis.schema.json",
  "title": "MortalOS v0 Genesis Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "body", "approvals"],
  "properties": {
    "kind": {
      "const": "mortalos.genesis"
    },
    "body": {
      "$ref": "#/$defs/genesisBody"
    },
    "approvals": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/approval"
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string"
    },
    "peerId": {
      "type": "string"
    },
    "publicKey": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "nonce": {
      "type": "string"
    },
    "custodian": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "public_key"],
      "properties": {
        "key_id": {
          "$ref": "#/$defs/peerId"
        },
        "public_key": {
          "$ref": "#/$defs/publicKey"
        }
      }
    },
    "quorum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "threshold"],
      "properties": {
        "type": {
          "type": "string"
        },
        "threshold": {
          "type": "integer"
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "signature"],
      "properties": {
        "key_id": {
          "$ref": "#/$defs/peerId"
        },
        "signature": {
          "$ref": "#/$defs/signature"
        }
      }
    },
    "genesisBody": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "hash_algorithm",
        "signature_algorithm",
        "genome_hash",
        "initial_state_root",
        "initial_custodians",
        "initial_quorum",
        "nonce"
      ],
      "properties": {
        "protocol_version": {
          "type": "string"
        },
        "hash_algorithm": {
          "type": "string"
        },
        "signature_algorithm": {
          "type": "string"
        },
        "genome_hash": {
          "$ref": "#/$defs/digest"
        },
        "initial_state_root": {
          "$ref": "#/$defs/digest"
        },
        "initial_custodians": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/custodian"
          }
        },
        "initial_quorum": {
          "$ref": "#/$defs/quorum"
        },
        "nonce": {
          "$ref": "#/$defs/nonce"
        }
      }
    }
  }
}
